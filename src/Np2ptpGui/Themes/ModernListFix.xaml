<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type ListView}">
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Default ListViewItem template draws hover/selection with SystemColors-based
         gradients and a beveled border (the classic Aero "3D" look) regardless of
         any Background/BorderBrush Setters - same class of built-in-trigger
         override GroupBox/CheckBox/GridViewColumnHeader needed a full retemplate
         to escape. Flatten to a plain rounded-corner tint. The tint lives in a
         separate sibling Border, not a parent, so toggling its Background/Opacity
         on hover/selection never fades the row's own text. -->
    <Style TargetType="{x:Type ListViewItem}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Grid>
                        <Border x:Name="SelectionBg" CornerRadius="4" Margin="2,1" Background="Transparent" />
                        <GridViewRowPresenter Content="{TemplateBinding Content}"
                                              Columns="{TemplateBinding GridView.ColumnCollection}"
                                              Margin="{TemplateBinding Padding}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectionBg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectionBg" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="SelectionBg" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default GroupBox template draws its frame with hardcoded SystemColors, not
         routed through the public BorderBrush property at all (a plain Setter has no
         effect). Reference look (Lossless Scaling-style): no border at all, a
         borderless "card" distinguished purely by a lighter fill than the page
         background, rounded corners, bold header text at the top of the card. -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <ContentPresenter ContentSource="Header"
                                              TextElement.FontSize="16"
                                              TextElement.FontWeight="SemiBold"
                                              TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              Margin="0,0,0,10" />
                            <ContentPresenter />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flat toggle-switch look for CheckBox (same IsChecked binding, no XAML
         changes needed at call sites) - matches the reference's oval track +
         sliding knob instead of a checkmark box. -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="12,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Track" Width="40" Height="20" CornerRadius="10"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                VerticalAlignment="Center">
                            <Border x:Name="Knob" Width="14" Height="14" CornerRadius="7"
                                    Background="White"
                                    HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="KnobTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X"
                                                         To="20" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- WPF's default GridViewColumnHeader template renders a raised/beveled
         classic-Windows "button" look regardless of Background/Foreground Setters
         (same class of built-in-trigger override XP Luna's Button/CheckBox needed
         a full retemplate to escape) - flatten it to a plain bottom-bordered cell. -->
    <Style TargetType="{x:Type GridViewColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,1">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
