<Application x:Class="Np2ptpGui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Np2ptpGui.Controls">
    <!--
        NOTE: App.xaml has no StartupUri (windows are created manually in App.xaml.cs's
        OnStartup), and without a StartupUri the WPF/.NET SDK markup compiler never emits
        the App.InitializeComponent() call nor compiles this file to BAML at all - so
        Application.Resources declared here are never actually loaded at runtime. The
        HintTextBoxStyle definition lives in Controls/HintTextBoxStyle.xaml instead, and
        each consuming view merges it directly. It's merged here too for documentation
        / forward-compatibility, in case App's startup wiring changes later.
    -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Np2ptpGui;component/Controls/HintTextBoxStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
